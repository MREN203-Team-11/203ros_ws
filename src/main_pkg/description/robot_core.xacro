<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:include filename="inertial_macros.xacro"/>

    <material name="white">
        <color rgba="1 1 1 1"/>
    </material>

    <material name="orange">
        <color rgba="1 0.3 0.1 1"/>
    </material>

    <material name="blue">
        <color rgba="0.2 0.2 1 1"/>
    </material>

    <material name="black">
        <color rgba="0 0 0 1"/>
    </material>

    <!-- BASE LINK -->

    <link name="base_link">

    </link>

    <!-- CHASSIS LINK -->

    <joint name="chassis_joint" type="fixed">
        <parent link="base_link"/>
        <child link="chassis"/>
        <origin xyz="0 0 0.060325"/>
    </joint>

    <link name="chassis">
        <visual>
            <origin xyz="0 0 0"/>
            <geometry>
                <box size="0.24765 0.2032 0.1016"/>
            </geometry>
            <material name="white"/>
        </visual>
        <collision>
            <origin xyz="0 0 0"/>
            <geometry>
                <box size="0.24765 0.2032 0.1016"/>
            </geometry>
        </collision>
        <xacro:inertial_box mass="0.7" x="0.24765" y="0.2032" z="0.1016">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_box>  
    </link>

    <gazebo reference="chassis">
        <material>Gazebo/White</material>
    </gazebo>

    <!-- FRONT LEFT WHEEL LINK -->

    <joint name="front_left_wheel_joint" type="continuous">
        <parent link="chassis"/>
        <child link="front_left_wheel"/>
        <origin xyz="0.092075 0.1190625 0" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
    </joint>
    
    <link name="front_left_wheel">
        <visual>
            <origin xyz="0 0 0" rpy="1.5708 0 0"/>
            <geometry>
                <cylinder radius="0.060325" length="0.034925"/>
            </geometry>
            <material name="blue"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="1.5708 0 0"/>
            <geometry>
                <cylinder radius="0.060325" length="0.034925"/>
            </geometry>
        </collision>
        <xacro:inertial_cylinder mass="0.2" length="0.034925" radius="0.060325">
            <origin xyz="0 0 0" rpy="1.5708 0 0"/>
        </xacro:inertial_cylinder> 
    </link>

    <gazebo reference="front_left_wheel">
        <material>Gazebo/Blue</material>
    </gazebo>

        <!-- FRONT RIGHT WHEEL LINK -->

    <joint name="front_right_wheel_joint" type="continuous">
        <parent link="chassis"/>
        <child link="front_right_wheel"/>
        <origin xyz="0.092075 -0.1190625 0" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
    </joint>
    
    <link name="front_right_wheel">
        <visual>
            <origin xyz="0 0 0" rpy="1.5708 0 0"/>
            <geometry>
                <cylinder radius="0.060325" length="0.034925"/>
            </geometry>
            <material name="blue"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="1.5708 0 0"/>
            <geometry>
                <cylinder radius="0.060325" length="0.034925"/>
            </geometry>
        </collision>
        <xacro:inertial_cylinder mass="0.2" length="0.034925" radius="0.060325">
            <origin xyz="0 0 0" rpy="1.5708 0 0"/>
        </xacro:inertial_cylinder>
    </link>

    <gazebo reference="front_right_wheel">
        <material>Gazebo/Blue</material>
    </gazebo>

        <!-- BACK LEFT WHEEL LINK -->

    <joint name="back_left_wheel_joint" type="continuous">
        <parent link="chassis"/>
        <child link="back_left_wheel"/>
        <origin xyz="-0.092075 0.1190625 0" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
    </joint>
    
    <link name="back_left_wheel">
        <visual>
            <origin xyz="0 0 0" rpy="1.5708 0 0"/>
            <geometry>
                <cylinder radius="0.060325" length="0.034925"/>
            </geometry>
            <material name="blue"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="1.5708 0 0"/>
            <geometry>
                <cylinder radius="0.060325" length="0.034925"/>
            </geometry>
        </collision>
        <xacro:inertial_cylinder mass="0.2" length="0.034925" radius="0.060325">
            <origin xyz="0 0 0" rpy="1.5708 0 0"/>
        </xacro:inertial_cylinder>
    </link>

    <gazebo reference="back_left_wheel">
        <material>Gazebo/Blue</material>
    </gazebo>

        <!-- BACK RIGHT WHEEL LINK -->

    <joint name="back_right_wheel_joint" type="continuous">
        <parent link="chassis"/>
        <child link="back_right_wheel"/>
        <origin xyz="-0.092075 -0.1190625 0" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
    </joint>
    
    <link name="back_right_wheel">
        <visual>
            <origin xyz="0 0 0" rpy="1.5708 0 0"/>
            <geometry>
                <cylinder radius="0.060325" length="0.034925"/>
            </geometry>
            <material name="blue"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="1.5708 0 0"/>
            <geometry>
                <cylinder radius="0.060325" length="0.034925"/>
            </geometry>
        </collision>
        <xacro:inertial_cylinder mass="0.2" length="0.034925" radius="0.060325">
            <origin xyz="0 0 0" rpy="1.5708 0 0"/>
        </xacro:inertial_cylinder>
    </link>

    <gazebo reference="back_right_wheel">
        <material>Gazebo/Blue</material>
    </gazebo>


</robot>
